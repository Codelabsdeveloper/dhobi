# Optional: subpath hosting (leading/trailing slashes are normalized at build time)
# Root domain: VITE_BASE_PATH=/
# GitHub Pages project site: VITE_BASE_PATH=/your-repo-name/  then npm run build:github-pages
VITE_BASE_PATH=/

# Optional: override WhatsApp business number (digits only, country code included)
# VITE_WHATSAPP_BUSINESS_E164=919620554794
# VITE_WHATSAPP_BUSINESS_DISPLAY=+91 9620554794
